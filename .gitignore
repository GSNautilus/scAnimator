# Dataset files are gitignored by default — only pbmc3k is tracked
datasets/*/frames.bin
datasets/*/colors.bin
datasets/*/expression.bin
datasets/*/gene_index.json
datasets/*/gene_ranks.json
datasets/*/metadata.json

# Un-ignore pbmc3k (the only public dataset)
!datasets/pbmc3k/*

# Source data (not redistributable)
*.RData
*.h5ad

# R project files
*.Rproj
.Rproj.user/
.Rhistory
.RData

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Local dev
serve.bat

# OS
.DS_Store
Thumbs.db
